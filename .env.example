# In .env.local kopieren und Werte setzen (wird nicht committet).

# Passcode für den Login (Single User).
PASSCODE=1234

# Geheimnis zum Signieren des Session-Cookies (min. 16 Zeichen, zufällig).
# Erzeugen z.B. mit: openssl rand -hex 32
SESSION_SECRET=bitte-durch-langen-zufallswert-ersetzen

# Turso/libSQL. Lokal reicht die SQLite-Datei (Default).
DATABASE_URL=file:local.db
# Nur für Turso-Cloud nötig:
DATABASE_AUTH_TOKEN=
